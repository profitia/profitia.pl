# ──────────────────────────────────────────────────────────────
# Profitia.pl - environment variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# Database (NeonDB PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT secret for admin sessions (generate with: openssl rand -base64 64)
JWT_SECRET="change-me-to-a-long-random-string"

# Application URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────
# Integrations - not yet active, prepare when ready
# ──────────────────────────────────────────────────────────────

# OpenAI (chat widget)
OPENAI_API_KEY="sk-..."
OPENAI_PRIMARY_MODEL="gpt-4.1"
# OPENAI_FALLBACK_MODEL="gpt-4.1-mini"

# Microsoft Teams booking
# TEAMS_BOOKING_URL="https://teams.microsoft.com/..."

# Mailchimp newsletter
# MAILCHIMP_API_KEY="..."
# MAILCHIMP_LIST_ID="..."
# MAILCHIMP_SERVER_PREFIX="us1"
