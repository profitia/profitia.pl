// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Contact form submissions
// ---------------------------------------------------------------------------
model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name    String
  email   String
  phone   String?
  company String?
  topic   String?  // inquiry topic - maps to ContactTopic
  message String   @db.Text

  // Submission metadata
  locale  String?  // 'pl' | 'en'
  source  String?  // pathname the form was submitted from

  // Consent metadata (GDPR Article 6(1)(a) audit trail)
  consentGdpr       Boolean   @default(false)
  consentNewsletter Boolean   @default(false)
  consentVersion    String?   // consent schema version
  consentAt         DateTime? // ISO timestamp of consent
  lawfulBasis       String?   @default("consent")

  // Processing state
  read      Boolean  @default(false)
  repliedAt DateTime?

  @@map("contacts")
}

// ---------------------------------------------------------------------------
// Newsletter subscribers
// ---------------------------------------------------------------------------
model Subscriber {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  email String  @unique
  name  String?

  active         Boolean   @default(true)
  confirmedAt    DateTime?
  unsubscribedAt DateTime?

  // Consent metadata (GDPR audit trail)
  consentVersion String?   // consent schema version
  consentAt      DateTime? // ISO timestamp of consent
  lawfulBasis    String?   @default("consent")

  // Submission metadata
  locale String? // 'pl' | 'en'
  source String? // pathname

  // TODO: link to Mailchimp / Brevo contact ID when integration is ready
  mailchimpId String?

  @@map("subscribers")
}

// ---------------------------------------------------------------------------
// Blog articles (CMS)
// ---------------------------------------------------------------------------
model Article {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug      String  @unique
  title     String
  excerpt   String? @db.Text
  content   String  @db.Text

  published    Boolean  @default(false)
  publishedAt  DateTime?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Authorship
  author   AdminUser? @relation(fields: [authorId], references: [id])
  authorId String?

  // ── Editorial System ────────────────────────────────────────────────────
  // Category slug - must match ArticleCategorySlug in lib/content/types.ts
  category    String?
  // Estimated reading time in minutes
  readingTime Int?
  // Cover image - public path (e.g. /images/articles/...) or absolute URL
  coverImage  String?
  // Whether this article is the featured/lead article on the index
  featured    Boolean @default(false)
  // Subtitle / standfirst - shown in article hero below title
  subtitle    String? @db.Text

  // Author (denormalized - supplements AdminUser relation for editorial display)
  authorName String?
  authorRole String?
  authorBio  String? @db.Text

  // Related content - slugs resolved at query time
  relatedSlugs String[] @default([])

  @@map("articles")
}

// ---------------------------------------------------------------------------
// Admin users (CMS access)
// ---------------------------------------------------------------------------
model AdminUser {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String  @unique
  name         String
  passwordHash String

  active Boolean @default(true)

  articles Article[]

  @@map("admin_users")
}
